{
  "expo": {
    "name": "Functional Wiehl",
    "slug": "functional-wiehl-fitness-tracker",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "functional-wiehl",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "de.functional-wiehl.app",
      "buildNumber": "1",
      "config": {
        "usesNonExemptEncryption": false
      },
      "infoPlist": {
        "NSCameraUsageDescription": "Functional Wiehl benoetigt Zugriff auf die Kamera fuer Fortschrittsfotos.",
        "NSPhotoLibraryUsageDescription": "Functional Wiehl benoetigt Zugriff auf die Fotobibliothek fuer Fortschrittsfotos.",
        "NSPhotoLibraryAddUsageDescription": "Functional Wiehl moechte Fotos in deiner Fotobibliothek speichern."
      },
      "privacyManifests": {
        "NSPrivacyAccessedAPITypes": [
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryUserDefaults",
            "NSPrivacyAccessedAPITypeReasons": ["CA92.1"]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategorySystemBootTime",
            "NSPrivacyAccessedAPITypeReasons": ["35F9.1"]
          }
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0A0A0A"
      },
      "package": "app.rork.functional-wiehl-fitness-tracker"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://app.functional-wiehl.de"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#FF6B35"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Functional Wiehl benoetigt Zugriff auf deine Fotos fuer Fortschrittsbilder.",
          "cameraPermission": "Functional Wiehl benoetigt Zugriff auf die Kamera fuer Fortschrittsfotos."
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "16.0"
          }
        }
      ],
      "@sentry/react-native/expo"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}

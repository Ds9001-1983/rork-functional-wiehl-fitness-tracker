# Functional Wiehl Fitness App - Environment Variables
# Copy this file to .env and fill in the values

NODE_ENV=production
BACKEND_PORT=3000

# PostgreSQL Database
DATABASE_URL=postgresql://app_user:YOUR_PASSWORD_HERE@localhost:5432/fitness_app
PGHOST=localhost
PGPORT=5432
PGUSER=app_user
PGPASSWORD=YOUR_PASSWORD_HERE
PGDATABASE=fitness_app

# Security
JWT_SECRET=CHANGE_THIS_TO_A_RANDOM_STRING

# URLs
CORS_ORIGIN=https://app.functional-wiehl.de
API_BASE_URL=https://app.functional-wiehl.de/api
EXPO_PUBLIC_API_BASE_URL=https://app.functional-wiehl.de

{
  "cli": {
    "version": ">= 18.5.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://app.functional-wiehl.de"
      },
      "ios": {
        "buildConfiguration": "Release"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "autoIncrement": true,
      "channel": "production",
      "ios": {
        "image": "latest",
        "buildConfiguration": "Release"
      },
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://app.functional-wiehl.de"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "sasse.dennis@googlemail.com",
        "ascAppId": "6761456533",
        "appleTeamId": "KXGPDQ8SWR"
      },
      "android": {
        "serviceAccountKeyPath": "../secrets/play-service-account.json",
        "track": "production"
      }
    }
  }
}

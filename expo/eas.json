{
  "cli": {
    "version": ">= 18.5.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_RORK_API_BASE_URL": "https://app.functional-wiehl.de"
      },
      "ios": {
        "buildConfiguration": "Release"
      }
    },
    "production": {
      "autoIncrement": true,
      "ios": {
        "image": "latest",
        "buildConfiguration": "Release"
      },
      "env": {
        "EXPO_PUBLIC_RORK_API_BASE_URL": "https://app.functional-wiehl.de",
        "EXPO_NO_DOCTOR": "1"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "sasse.dennis@googlemail.com",
        "ascAppId": "6761456533",
        "appleTeamId": "KXGPDQ8SWR"
      }
    }
  }
}

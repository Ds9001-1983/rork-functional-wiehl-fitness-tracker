{
  "cli": {
    "version": ">= 18.4.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_RORK_API_BASE_URL": "https://app.functional-wiehl.de"
      }
    },
    "production": {
      "autoIncrement": true,
      "ios": {
        "image": "latest"
      },
      "env": {
        "EXPO_PUBLIC_RORK_API_BASE_URL": "https://app.functional-wiehl.de",
        "EXPO_NO_DOCTOR": "1"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": "6761456533"
      }
    }
  }
}
